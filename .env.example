# OpenRouter API key for LLM scoring
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Email address to receive job alerts
ALERT_EMAIL_TO=your_email@gmail.com

# Gmail OAuth2 setup:
# 1. Go to https://console.cloud.google.com/ > APIs & Services > Credentials
# 2. Enable Gmail API, create OAuth 2.0 Desktop credentials
# 3. Download credentials.json and place in DATA_DIR
# 4. Run: python auth_gmail.py
# 5. token.json will be generated alongside credentials.json
#
# Both files (credentials.json, token.json) must be in DATA_DIR
# (mounted at /data inside Docker). No password needed.
